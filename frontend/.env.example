# Copy to .env.local and fill in.

# ===== Required =====

# zkVerify Volta testnet seed phrase (12 words).
# Register at https://docs.zkverify.io/network/testnet to get a Volta account
# and export the seed. Server-side only, never exposed to the browser.
ZKVERIFY_SEED=

# WebSocket URL of your deployed TLSNotary verifier.
# Deploy your own from https://github.com/JetHalo/zktls_sever (Railway, Singapore region).
NEXT_PUBLIC_DEFAULT_NOTARY_URL=wss://your-verifier.up.railway.app
